# =============================================================================
# VungTau Dream Homes — Production Environment Variables
# =============================================================================
# Copy this file to .env.production and fill in real values.
# Variables prefixed with VITE_ are exposed to the browser bundle.
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase (REQUIRED)
# ---------------------------------------------------------------------------
# Project URL from https://supabase.com/dashboard/project/<ref>/settings/api
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Anon (public) key — safe to expose in the browser
VITE_SUPABASE_ANON_KEY=eyJ...your_anon_key_here

# Service-role key — server-side ONLY (scripts, migrations, API routes)
# NEVER bundle this into the client build
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key_here

# Direct Postgres connection via Supabase pooler (scripts & migrations)
DATABASE_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres

# ---------------------------------------------------------------------------
# Sentry — Error Tracking (RECOMMENDED)
# ---------------------------------------------------------------------------
# Create a project at https://sentry.io → Settings → Client Keys (DSN)
# The app already has @sentry/react + @sentry/vite-plugin installed.
# Leave blank to disable Sentry in production.
SENTRY_DSN=https://YOUR_PUBLIC_KEY@oXXXXXX.ingest.sentry.io/XXXXXXX
# Optional compatibility key (also supported)
NEXT_PUBLIC_SENTRY_DSN=

# ---------------------------------------------------------------------------
# Google Analytics 4 (RECOMMENDED)
# ---------------------------------------------------------------------------
# Get your Measurement ID from https://analytics.google.com → Admin → Data Streams
# Format: G-XXXXXXXXXX
# Leave blank to disable GA.
VITE_GA_ID=G-XXXXXXXXXX
# Optional compatibility key (also supported)
NEXT_PUBLIC_GA_ID=

# ---------------------------------------------------------------------------
# Dify AI Chatbot (OPTIONAL)
# ---------------------------------------------------------------------------
# If using the AI chatbot feature powered by Dify.ai
VITE_DIFY_API_BASE=https://api.dify.ai/v1
VITE_DIFY_API_KEY=app-your_dify_api_key_here

# ---------------------------------------------------------------------------
# App Metadata
# ---------------------------------------------------------------------------
VITE_APP_NAME=VungTauLand
VITE_APP_URL=https://vungtauland.store
VITE_APP_VERSION=1.0.0

# ---------------------------------------------------------------------------
# Vercel (deployment — not needed in .env.production, set in Vercel dashboard)
# ---------------------------------------------------------------------------
# VERCEL_TOKEN=  (set via `vercel env add` or Vercel dashboard)
